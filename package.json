{
  "name": "frame-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "ai:prepare": "node scripts/ai-composer/export-ai-data.mjs && node scripts/ai-composer/generate-recipes.mjs",
    "ai:recipes": "node scripts/ai-composer/generate-recipes.mjs",
    "ai:evaluate": "node scripts/ai-composer/evaluate-components.mjs",
    "ai:mcp": "node scripts/ai-composer/mcp-server.mjs",
    "ai:mcp:test": "node scripts/ai-composer/test-mcp-poc.mjs",
    "qa:docs": "node scripts/qa-doc-examples.mjs",
    "start:playground": "ng serve playground",
    "start:docs": "ng serve docs",
    "watch": "ng build foundation --watch --configuration development",
    "watch:components": "ng build components --watch --configuration development",
    "test": "ng test foundation --watch=false && ng test components --watch=false",
    "test:components": "ng test components --watch=false",
    "test:playground": "ng test playground --watch=false",
    "serve:ssr:docs": "node dist/docs/server/server.mjs",
    "build:playground": "ng build playground",
    "build:docs": "ng build docs",
    "build:foundation": "ng build foundation --configuration production",
    "build:components": "ng build components --configuration production",
    "build:packages": "npm run build:foundation && npm run build:components",
    "pack:foundation": "cd dist/foundation && npm pack --dry-run",
    "pack:components": "cd dist/components && npm pack --dry-run",
    "publish:foundation": "ng build foundation --configuration production && cd dist/foundation && npm publish --access public --tag latest",
    "publish:components": "ng build components --configuration production && cd dist/components && npm publish --access public --tag latest"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.16",
    "@angular/compiler": "^21.2.16",
    "@angular/core": "^21.2.16",
    "@angular/forms": "^21.2.16",
    "@angular/platform-browser": "^21.2.16",
    "@angular/platform-server": "^21.2.16",
    "@angular/router": "^21.2.16",
    "@angular/ssr": "^21.2.14",
    "@ng-icons/core": "^33.2.3",
    "@ng-icons/tabler-icons": "^33.2.3",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "openai": "^6.42.0",
    "rxjs": "~7.8.0",
    "shiki": "^4.2.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.16",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "json-server": "^1.0.0-beta.15",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
